---
// Welcome.astro - Hero Section Premium
import memoji from "../assets/memoji4.png";
import LogoInstagram from "./LogoInstagram.astro";
import Slider from "./Slider.astro";
---

<section
  id="inicio"
  class="relative w-full min-h-screen bg-transparent flex flex-col justify-between items-center overflow-hidden pt-28 pb-16"
>
  <!-- Background glow for Hero area -->
  <div class="absolute top-[20%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-gradient-to-tr from-blue-500/10 to-indigo-500/10 rounded-full blur-[120px] -z-10"></div>

  <div
    class="z-10 w-full max-w-5xl px-6 flex flex-col gap-6 text-center items-center my-auto"
  >
    <!-- Profile / Memoji -->
    <div class="hero-anim opacity-0 translate-y-6">
      <div class="relative group">
        <!-- Aura Glow behind avatar -->
        <div class="absolute inset-0 bg-gradient-to-tr from-blue-500/20 via-indigo-500/20 to-purple-500/20 rounded-full blur-xl group-hover:scale-110 transition-transform duration-500 -z-10"></div>
        
        <div
          class="relative w-28 h-28 md:w-36 md:h-36 rounded-full bg-gradient-to-tr from-white/20 to-white/5 p-[1px] shadow-2xl backdrop-blur-sm transform transition-all duration-500 group-hover:scale-105"
        >
          <div class="w-full h-full rounded-full bg-[#121217] overflow-hidden p-1">
            <img
              class="w-full h-full object-contain drop-shadow-[0_10px_15px_rgba(0,0,0,0.5)] transform hover:rotate-3 transition-transform duration-300"
              src={memoji.src}
              alt="Brayant Flores Memoji"
            />
          </div>
        </div>
        
        <a
          href="https://www.instagram.com/brayan_tsj/"
          target="_blank"
          class="absolute -bottom-2 -right-2 bg-[#121217]/90 backdrop-blur-md shadow-xl border border-white/10 rounded-full px-3 py-1.5 flex items-center gap-1.5 hover:bg-zinc-900 hover:border-white/25 transition-all duration-300"
        >
          <LogoInstagram class="w-4 h-4 text-pink-400" />
          <span class="text-xs font-semibold text-zinc-300 font-heading tracking-wide"
            >@Brayan_tsj</span
          >
        </a>
      </div>
    </div>

    <!-- Main Headline -->
    <h1
      class="hero-anim opacity-0 translate-y-6 text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight text-white leading-[1.05] font-heading mt-4"
    >
      Experiencias digitales <br class="hidden md:block" />
      <span
        class="bg-gradient-to-r from-blue-300 via-indigo-200 to-white bg-clip-text text-transparent bg-300% animate-gradient"
      >
        que impactan.
      </span>
    </h1>

    <!-- Subtitle -->
    <p
      class="hero-anim opacity-0 translate-y-6 text-base md:text-xl text-zinc-400 max-w-2xl font-light leading-relaxed px-4"
    >
      Soy <span class="text-white font-medium">Brayant Flores</span>. Desarrollo sitios web modernos, eCommerce de alto rendimiento y aplicaciones web premium que elevan marcas al siguiente nivel.
    </p>

    <!-- Call to Action -->
    <div class="hero-anim opacity-0 translate-y-6 flex flex-col sm:flex-row gap-4 mt-6 w-full sm:w-auto px-6">
      <a
        href="#contacto"
        class="text-center px-8 py-3 rounded-full bg-white text-black font-semibold shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_35px_rgba(255,255,255,0.5)] transition-all duration-300 hover:scale-105 hover:-translate-y-0.5 font-heading cursor-pointer"
      >
        Contactar
      </a>
      <a
        href="#proyectos"
        class="text-center px-8 py-3 rounded-full border border-zinc-800 text-zinc-300 font-semibold bg-white/5 hover:bg-white/10 hover:text-white hover:border-zinc-600 transition-all duration-300 hover:scale-105 hover:-translate-y-0.5 font-heading"
      >
        Ver Proyectos
      </a>
    </div>
  </div>

  <!-- Logos Slider integrated at the bottom -->
  <div class="hero-anim opacity-0 translate-y-6 w-full mt-12 md:mt-20">
    <Slider />
  </div>
</section>

<script>
  import gsap from "gsap";

  document.addEventListener("astro:page-load", () => {
    initHeroAnimation();
  });

  // Initial load support
  window.addEventListener("DOMContentLoaded", () => {
    initHeroAnimation();
  });

  function initHeroAnimation() {
    const elements = document.querySelectorAll(".hero-anim");
    if (elements.length === 0) return;

    gsap.to(elements, {
      y: 0,
      opacity: 1,
      duration: 1.2,
      stagger: 0.12,
      ease: "power4.out",
      delay: 0.1, // Small delay before starting
    });
  }
</script>
