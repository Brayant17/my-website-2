---
// NavMenu.astro - Navbar Glassmorphic Premium
---

<header
  id="nav-container"
  class="fixed top-4 left-0 w-full z-50 px-4 md:px-8 transition-all duration-300"
>
  <div
    class="max-w-5xl mx-auto w-full glassmorphism rounded-full px-6 py-4 flex items-center justify-between shadow-2xl transition-all duration-300"
  >
    <!-- Logo -->
    <a href="#inicio" class="group flex items-center gap-2">
      <span class="text-2xl font-bold tracking-tight text-white font-heading">
        Brayant<span class="text-blue-300 font-extrabold group-hover:text-purple-300 transition-colors duration-300">.F</span>
      </span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden md:flex items-center gap-1">
      <a href="#inicio" class="nav-link">Inicio</a>
      <a href="#sobre-mi" class="nav-link">Sobre Mí</a>
      <a href="#servicios" class="nav-link">Servicios</a>
      <a href="#proyectos" class="nav-link">Proyectos</a>
      <a href="#contacto" class="nav-link-cta">Contacto</a>
    </nav>

    <!-- Mobile Menu Toggle Button -->
    <button
      class="group md:hidden relative flex items-center justify-center w-10 h-10 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all duration-300 text-white focus:outline-none"
      id="menu-toggle"
      aria-label="Abrir menú"
    >
      <div class="flex flex-col justify-between w-5 h-4 transition-transform duration-300">
        <span class="w-full h-0.5 bg-white rounded-full transition-all duration-300 origin-left" id="bar1"></span>
        <span class="w-full h-0.5 bg-white rounded-full transition-all duration-300" id="bar2"></span>
        <span class="w-full h-0.5 bg-white rounded-full transition-all duration-300 origin-left" id="bar3"></span>
      </div>
    </button>
  </div>
</header>

<!-- Mobile Navigation Drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden flex-col justify-between p-8 glassmorphism text-white"
>
  <!-- Background Noise inside Mobile Menu -->
  <div class="absolute inset-0 bg-noise z-0 opacity-10"></div>
  
  <div class="w-full flex justify-between items-center z-10 mt-20">
    <span class="text-xl font-bold font-heading text-white">Menú</span>
  </div>

  <!-- Mobile Links List -->
  <nav class="flex flex-col gap-6 my-auto z-10">
    <a href="#inicio" class="mobile-nav-link">Inicio</a>
    <a href="#sobre-mi" class="mobile-nav-link">Sobre Mí</a>
    <a href="#servicios" class="mobile-nav-link">Servicios</a>
    <a href="#proyectos" class="mobile-nav-link">Proyectos</a>
    <a href="#contacto" class="mobile-nav-link-cta">Contacto</a>
  </nav>

  <!-- Mobile Footer / Socials -->
  <div class="w-full border-t border-white/5 pt-6 flex flex-col gap-4 z-10">
    <p class="text-sm text-zinc-400 font-light text-center">
      Juntos, diseñando el futuro digital.
    </p>
    <div class="flex justify-center gap-6">
      <a href="https://www.instagram.com/brayan_tsj/" target="_blank" class="text-sm text-zinc-400 hover:text-white transition-colors">Instagram</a>
      <a href="https://www.linkedin.com/in/brayant-flores/" target="_blank" class="text-sm text-zinc-400 hover:text-white transition-colors">LinkedIn</a>
    </div>
  </div>
</div>

<style>
  /* Header Floating Animation & State Scrolled */
  #nav-container {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .nav-scrolled {
    top: 1rem !important;
  }
  
  .nav-scrolled > div {
    background: rgba(13, 13, 17, 0.8) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-color: rgba(255, 255, 255, 0.08) !important;
    padding-top: 0.75rem !important;
    padding-bottom: 0.75rem !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4) !important;
  }

  /* Desktop Nav Link Styles */
  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: #a1a1aa; /* text-zinc-400 */
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    transition: all 0.3s ease;
    position: relative;
  }

  .nav-link:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link-cta {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: #000000;
    background: #ffffff;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.25);
    transition: all 0.3s ease;
    margin-left: 0.5rem;
  }

  .nav-link-cta:hover {
    transform: scale(1.05);
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.4);
    background: #f4f4f5;
  }

  /* Mobile Link Styles */
  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: #a1a1aa;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .mobile-nav-link:hover {
    color: #ffffff;
    transform: translateX(10px);
  }

  .mobile-nav-link-cta {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #93c5fd, #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: all 0.3s ease;
    display: inline-block;
  }
  
  .mobile-nav-link-cta:hover {
    transform: translateX(10px) scale(1.02);
  }
</style>

<script>
  import gsap from "gsap";

  document.addEventListener("astro:page-load", () => {
    initNav();
  });

  // Initial load
  window.addEventListener("DOMContentLoaded", () => {
    initNav();
  });

  function initNav() {
    const navContainer = document.getElementById("nav-container");
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const body = document.body;
    
    // Burger lines
    const bar1 = document.getElementById("bar1");
    const bar2 = document.getElementById("bar2");
    const bar3 = document.getElementById("bar3");

    // 1. Scroll Effect (Sticky Navbar transition)
    window.addEventListener("scroll", () => {
      if (window.scrollY > 40) {
        navContainer?.classList.add("nav-scrolled");
      } else {
        navContainer?.classList.remove("nav-scrolled");
      }
    });

    // Make sure initial state matches
    if (window.scrollY > 40) {
      navContainer?.classList.add("nav-scrolled");
    }

    // 2. Mobile Drawer Toggle
    let isMenuOpen = false;

    menuToggle?.addEventListener("click", () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        // Open Mobile Menu
        body.classList.add("overflow-hidden");
        mobileMenu?.classList.remove("hidden");
        mobileMenu?.classList.add("flex");

        // Animate Hamburger to X
        bar1?.classList.add("rotate-45", "translate-y-1.5");
        bar2?.classList.add("scale-x-0");
        bar3?.classList.add("-rotate-45", "-translate-y-1.5");

        // GSAP transition for mobile menu links
        gsap.fromTo(
          ".mobile-nav-link, .mobile-nav-link-cta",
          { opacity: 0, x: -30 },
          {
            opacity: 1,
            x: 0,
            duration: 0.6,
            stagger: 0.08,
            ease: "power3.out",
            overwrite: "auto",
          }
        );
      } else {
        closeDrawer();
      }
    });

    // Close mobile menu on link clicks
    const mobileLinks = document.querySelectorAll(".mobile-nav-link, .mobile-nav-link-cta");
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        closeDrawer();
      });
    });

    function closeDrawer() {
      isMenuOpen = false;
      body.classList.remove("overflow-hidden");
      
      // Animate Hamburger back
      bar1?.classList.remove("rotate-45", "translate-y-1.5");
      bar2?.classList.remove("scale-x-0");
      bar3?.classList.remove("-rotate-45", "-translate-y-1.5");

      // Animate drawer out and then hide
      gsap.to(mobileMenu, {
        opacity: 0,
        duration: 0.4,
        ease: "power2.inOut",
        onComplete: () => {
          mobileMenu?.classList.add("hidden");
          mobileMenu?.classList.remove("flex");
          gsap.set(mobileMenu, { clearProps: "opacity" });
        }
      });
    }

    // Handle screen resize
    const mediaQuery = window.matchMedia("(min-width: 768px)");
    function handleSizeChange(e: MediaQueryList | MediaQueryListEvent) {
      if (e.matches && isMenuOpen) {
        closeDrawer();
      }
    }
    mediaQuery.addEventListener("change", handleSizeChange);
  }
</script>
