---
// Stack.astro - Technical Showcase Premium
---

<section
  id="stack"
  class="py-32 relative overflow-hidden bg-[#0D0D11] border-t border-zinc-800"
>
  <!-- Glow effects in background -->
  <div class="absolute top-[30%] right-[-10%] w-[350px] h-[350px] bg-blue-500/5 rounded-full blur-[120px] -z-10 animate-pulse"></div>
  <div class="absolute bottom-[20%] left-[-10%] w-[350px] h-[350px] bg-purple-500/5 rounded-full blur-[120px] -z-10 animate-pulse" style="animation-delay: 2s;"></div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="mb-16 text-center stack-header opacity-0 translate-y-4">
      <span class="text-xs font-mono text-zinc-500 uppercase tracking-widest block mb-2">
        [02] — Stack Tecnológico
      </span>
      <h2 class="text-4xl md:text-5xl font-bold font-heading text-white tracking-tight">
        Mi Arsenal <span class="bg-gradient-to-r from-blue-300 to-purple-300 bg-clip-text text-transparent">de Desarrollo.</span>
      </h2>
      <p class="text-zinc-400 max-w-xl mx-auto mt-4 text-sm md:text-base font-light leading-relaxed">
        Una selección de tecnologías modernas y robustas que utilizo para construir soluciones web estables, veloces y escalables.
      </p>
    </div>
  </div>

  <!-- Full-Width Seamless Text Marquee -->
  <div class="w-full overflow-hidden flex select-none mb-20 border-y border-white/5 py-5 bg-[#121217]/20 relative z-10 [mask-image:linear-gradient(to_right,transparent,black_15%,black_85%,transparent)]">
    <!-- Track 1 -->
    <div class="flex gap-16 pr-16 shrink-0 animate-stack-marquee text-xs font-mono uppercase tracking-[0.25em] text-zinc-500 items-center">
      <span>React</span> <span class="text-blue-300">✦</span>
      <span>Astro</span> <span class="text-[#FF5D01]">✦</span>
      <span>Tailwind CSS</span> <span class="text-[#38BDF8]">✦</span>
      <span>Shopify</span> <span class="text-[#96bf48]">✦</span>
      <span>WordPress</span> <span class="text-[#21759b]">✦</span>
      <span>Figma</span> <span class="text-[#F24E1E]">✦</span>
      <span>Framer</span> <span class="text-blue-500">✦</span>
      <span>JavaScript</span> <span class="text-yellow-400">✦</span>
      <span>Node.js</span> <span class="text-[#339933]">✦</span>
      <span>Git & GitHub</span> <span class="text-[#F05032]">✦</span>
    </div>
    <!-- Track 2 (Duplicate for Seamless Loop) -->
    <div class="flex gap-16 pr-16 shrink-0 animate-stack-marquee text-xs font-mono uppercase tracking-[0.25em] text-zinc-500 items-center" aria-hidden="true">
      <span>React</span> <span class="text-blue-300">✦</span>
      <span>Astro</span> <span class="text-[#FF5D01]">✦</span>
      <span>Tailwind CSS</span> <span class="text-[#38BDF8]">✦</span>
      <span>Shopify</span> <span class="text-[#96bf48]">✦</span>
      <span>WordPress</span> <span class="text-[#21759b]">✦</span>
      <span>Figma</span> <span class="text-[#F24E1E]">✦</span>
      <span>Framer</span> <span class="text-blue-500">✦</span>
      <span>JavaScript</span> <span class="text-yellow-400">✦</span>
      <span>Node.js</span> <span class="text-[#339933]">✦</span>
      <span>Git & GitHub</span> <span class="text-[#F05032]">✦</span>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <!-- Tech Grid Categorized -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Category 1: Frontend & Core -->
      <div class="stack-category-col opacity-0 translate-y-8 flex flex-col gap-4">
        <div class="flex items-center gap-2 border-b border-white/5 pb-3">
          <span class="text-blue-300 text-sm">✦</span>
          <h3 class="text-lg font-bold font-heading text-zinc-300">Frontend & Core</h3>
        </div>
        
        <!-- React Card -->
        <div class="tech-card group" data-glow-color="#61DAFB">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#61DAFB] group-hover:bg-[#61DAFB]/10 group-hover:border-[#61DAFB]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-45 transition-transform duration-700"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="2"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">React</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Librería Principal</span>
              </div>
            </div>
            <span class="tech-badge bg-[#61DAFB]/10 text-[#61DAFB]">Avanzado</span>
          </div>
        </div>

        <!-- Astro Card -->
        <div class="tech-card group" data-glow-color="#FF5D01">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#FF5D01] group-hover:bg-[#FF5D01]/10 group-hover:border-[#FF5D01]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2zM12 18l-4-4h8l-4 4z"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Astro</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Sitios Estáticos & SSR</span>
              </div>
            </div>
            <span class="tech-badge bg-[#FF5D01]/10 text-[#FF5D01]">Experto</span>
          </div>
        </div>

        <!-- Tailwind CSS Card -->
        <div class="tech-card group" data-glow-color="#38BDF8">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#38BDF8] group-hover:bg-[#38BDF8]/10 group-hover:border-[#38BDF8]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Tailwind CSS</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Estilos Utilitarios</span>
              </div>
            </div>
            <span class="tech-badge bg-[#38BDF8]/10 text-[#38BDF8]">Experto</span>
          </div>
        </div>

        <!-- JavaScript Card -->
        <div class="tech-card group" data-glow-color="#F7DF1E">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#F7DF1E] group-hover:bg-[#F7DF1E]/10 group-hover:border-[#F7DF1E]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="9" y2="15"></line><line x1="9" y1="15" x2="12" y2="15"></line></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">JavaScript (ES6+)</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Lógica Interactiva</span>
              </div>
            </div>
            <span class="tech-badge bg-[#F7DF1E]/10 text-[#F7DF1E]">Avanzado</span>
          </div>
        </div>

      </div>

      <!-- Category 2: CMS & eCommerce -->
      <div class="stack-category-col opacity-0 translate-y-8 flex flex-col gap-4" style="transition-delay: 150ms;">
        <div class="flex items-center gap-2 border-b border-white/5 pb-3">
          <span class="text-purple-300 text-sm">✦</span>
          <h3 class="text-lg font-bold font-heading text-zinc-300">CMS & eCommerce</h3>
        </div>

        <!-- Shopify Card -->
        <div class="tech-card group" data-glow-color="#96bf48">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#96bf48] group-hover:bg-[#96bf48]/10 group-hover:border-[#96bf48]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Shopify</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Tiendas Online</span>
              </div>
            </div>
            <span class="tech-badge bg-[#96bf48]/10 text-[#96bf48]">Experto</span>
          </div>
        </div>

        <!-- WordPress Card -->
        <div class="tech-card group" data-glow-color="#21759b">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#21759b] group-hover:bg-[#21759b]/10 group-hover:border-[#21759b]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"></path><path d="M20 12a8 8 0 1 0-16 0"></path><path d="M12 2v20"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">WordPress</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Sitios Dinámicos & Blog</span>
              </div>
            </div>
            <span class="tech-badge bg-[#21759b]/10 text-[#21759b]">Experto</span>
          </div>
        </div>

        <!-- Elementor Card -->
        <div class="tech-card group" data-glow-color="#92003B">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#92003B] group-hover:bg-[#92003B]/10 group-hover:border-[#92003B]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="15"></line></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Elementor Pro</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Maquetador Visual</span>
              </div>
            </div>
            <span class="tech-badge bg-[#92003B]/10 text-[#92003B]">Experto</span>
          </div>
        </div>

      </div>

      <!-- Category 3: Design & Tools -->
      <div class="stack-category-col opacity-0 translate-y-8 flex flex-col gap-4" style="transition-delay: 300ms;">
        <div class="flex items-center gap-2 border-b border-white/5 pb-3">
          <span class="text-indigo-300 text-sm">✦</span>
          <h3 class="text-lg font-bold font-heading text-zinc-300">Diseño & Entorno</h3>
        </div>

        <!-- Figma Card -->
        <div class="tech-card group" data-glow-color="#F24E1E">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#F24E1E] group-hover:bg-[#F24E1E]/10 group-hover:border-[#F24E1E]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"></path><path d="M12 2h3.5a3.5 3.5 0 1 1 0 7H12V2z"></path><path d="M12 12.5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 1 1-7 0z"></path><path d="M5 19.5A3.5 3.5 0 0 1 8.5 23H12v-3.5a3.5 3.5 0 1 1-7 0z"></path><path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Figma</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Diseño UX/UI</span>
              </div>
            </div>
            <span class="tech-badge bg-[#F24E1E]/10 text-[#F24E1E]">Avanzado</span>
          </div>
        </div>

        <!-- Framer Card -->
        <div class="tech-card group" data-glow-color="#0055FF">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#0055FF] group-hover:bg-[#0055FF]/10 group-hover:border-[#0055FF]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 2h14v7.5L12 16v6l-7-7.5V2z"></path></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Framer</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">No-Code Premium</span>
              </div>
            </div>
            <span class="tech-badge bg-[#0055FF]/10 text-[#0055FF]">Avanzado</span>
          </div>
        </div>

        <!-- Git Card -->
        <div class="tech-card group" data-glow-color="#F05032">
          <div class="tech-card-inner">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#F05032] group-hover:bg-[#F05032]/10 group-hover:border-[#F05032]/30 transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm font-heading">Git & GitHub</h4>
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-wider">Control de Versiones</span>
              </div>
            </div>
            <span class="tech-badge bg-[#F05032]/10 text-[#F05032]">Avanzado</span>
          </div>
        </div>

      </div>

    </div>

  </div>
</section>

<style>
  /* Premium Glassmorphic Card Styles with custom Glow on Hover */
  .tech-card {
    position: relative;
    border-radius: 1.25rem;
    padding: 1px; /* Para el borde degradado extra fino */
    background: rgba(255, 255, 255, 0.03);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tech-card-inner {
    border-radius: 1.22rem;
    padding: 1.25rem;
    background: rgba(20, 20, 25, 0.6);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.4s ease;
  }

  /* Hover States */
  .tech-card:hover {
    transform: translateY(-4px);
    background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
  }

  .tech-card:hover .tech-card-inner {
    background: rgba(26, 26, 32, 0.85);
  }

  /* Dynamic Shadow Glow in Hover using Javascript Custom property */
  .tech-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1.25rem;
    background: var(--glow-color, rgba(255, 255, 255, 0.15));
    filter: blur(25px);
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: -1;
    pointer-events: none;
  }

  .tech-card:hover::before {
    opacity: 0.25;
  }

  /* Badge Styles */
  .tech-badge {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    display: inline-block;
  }

  /* Stack Text Marquee Animation */
  .animate-stack-marquee {
    animation: stack-marquee-scroll 25s linear infinite;
  }

  @keyframes stack-marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  /* Pause stack scrolling on hover */
  .w-full:hover .animate-stack-marquee {
    animation-play-state: paused;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    initStack();
  });

  window.addEventListener("DOMContentLoaded", () => {
    initStack();
  });

  function initStack() {
    // 1. Inject custom glow colors from inline attributes
    const cards = document.querySelectorAll(".tech-card");
    cards.forEach((card) => {
      const color = card.getAttribute("data-glow-color");
      if (color) {
        (card as HTMLElement).style.setProperty("--glow-color", color);
      }
    });

    // 2. Scroll Animations
    gsap.to(".stack-header", {
      scrollTrigger: {
        trigger: ".stack-header",
        start: "top 80%",
      },
      y: 0,
      opacity: 1,
      duration: 1,
      ease: "power3.out",
    });

    const categories = document.querySelectorAll(".stack-category-col");
    if (categories.length) {
      gsap.to(categories, {
        scrollTrigger: {
          trigger: categories[0],
          start: "top 85%",
        },
        y: 0,
        opacity: 1,
        duration: 1,
        stagger: 0.15,
        ease: "power3.out",
      });
    }
  }
</script>
