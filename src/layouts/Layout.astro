---
import Footer from "../components/Footer.astro";
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/logoBF.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<meta
			name="description"
			content="Brayant Flores - Desarrollador Web Frontend. Creo experiencias digitales de alto impacto, sitios web modernos, e-commerce y aplicaciones web premium a medida."
		/>
		<meta
			name="keywords"
			content="Brayant Flores, Desarrollador Web, React, Astro, E-commerce, Shopify, WordPress, Diseñador Web, Sitios Web"
		/>
		<meta name="author" content="Brayant Flores" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta
			property="og:title"
			content="Brayant Flores — Desarrollador Web"
		/>
		<meta
			property="og:description"
			content="Desarrollo de sitios web modernos, e-commerce y aplicaciones web que elevan tu marca al siguiente nivel."
		/>
		<meta property="og:image" content="/og-image.png" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>

		<title>{title} | Desarrollador Web Premium</title>

		<!-- Clarity -->
		<script type="text/javascript">
			(function (c, l, a, r, i, t, y) {
				c[a] =
					c[a] ||
					function () {
						(c[a].q = c[a].q || []).push(arguments);
					};
				t = l.createElement(r);
				t.async = 1;
				t.src = "https://www.clarity.ms/tag/" + i;
				y = l.getElementsByTagName(r)[0];
				y.parentNode.insertBefore(t, y);
			})(window, document, "clarity", "script", "x5gmsiqru6");
		</script>
	</head>
	<body class="">
		<slot />
	</body>
	<Footer />
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
